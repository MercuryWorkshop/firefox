FINAL_LIBRARY = "js"

# Includes should be relative to parent path
LOCAL_INCLUDES += ["!..", ".."]

include("../js-compileflags.mozbuild")
include("../js-config.mozbuild")
include("../js-cxxflags.mozbuild")

UNIFIED_SOURCES += [
    "AsmJS.cpp",
    "WasmAnyRef.cpp",
    "WasmBinary.cpp",
    "WasmBuiltinModule.cpp",
    "WasmBuiltins.cpp",
    "WasmCode.cpp",
    "WasmCodegenTypes.cpp",
    "WasmCompile.cpp",
    "WasmComponent.cpp",
    "WasmContext.cpp",
    "WasmDebug.cpp",
    "WasmDebugFrame.cpp",
    "WasmDump.cpp",
    "WasmFeatures.cpp",
    "WasmFrameIter.cpp",
    "WasmGC.cpp",
    "WasmGcObject.cpp",
    "WasmGenerator.cpp",
    "WasmInitExpr.cpp",
    "WasmInstance.cpp",
    "WasmIonCompile.cpp",
    "WasmJS.cpp",
    "WasmLog.cpp",
    "WasmMemory.cpp",
    "WasmMetadata.cpp",
    "WasmModule.cpp",
    "WasmModuleTypes.cpp",
    "WasmOpIter.cpp",
    "WasmPI.cpp",
    "WasmProcess.cpp",
    "WasmRealm.cpp",
    "WasmSerialize.cpp",
    "WasmSignalHandlers.cpp",
    "WasmStacks.cpp",
    "WasmStaticTypeDefs.cpp",
    "WasmStructLayout.cpp",
    "WasmSummarizeInsn.cpp",
    "WasmTable.cpp",
    "WasmTypeDef.cpp",
    "WasmValidate.cpp",
    "WasmValType.cpp",
    "WasmValue.cpp",
]

# Re-architected JS->wasm JIT: separate TUs (not unified) -- file-static globals
# and anonymous-namespace helpers would collide if merged with each other/WasmJS.cpp.
SOURCES += [
    "WasmJitBackend.cpp",
    "WasmJitRuntime.cpp",
    "WasmJitWarp.cpp",
]

# Scalar v128 helpers for the interpreter, compiled WITHOUT -msimd128 so clang
# (v23) cannot emit the SIMD instructions it miscompiles for the composite
# extmul/avgr intrinsics (separate non-unified TU => not inlined into the
# -msimd128 interpreter loop, where the scalar code gets idiom-recognized back
# into the buggy instruction). See WasmInterpSimdScalar.h.
SOURCES += ["WasmInterpSimdScalar.cpp"]
SOURCES["WasmInterpSimdScalar.cpp"].flags += ["-mno-simd128"]

# In a JS_CODEGEN_NONE build (--disable-jit) the rabaldr baseline compiler is
# dead, but with ENABLE_WASM_SIMD enabled (for the in-process interpreter's
# front-end validation) its SIMD emitters reference backend-only macro-assembler
# ops the none-backend lacks. These TUs locally `#undef ENABLE_WASM_SIMD`; build
# them non-unified so that undef cannot leak into the SIMD-aware front-end TUs
# (e.g. WasmBinary.cpp) that share a unified compilation unit.
#
# WasmStubs.cpp is moved here too: it has the same dead-SIMD-codegen problem and
# needs a post-include `#undef ENABLE_WASM_SIMD`, which would leak into the
# front-end SIMD TUs if it stayed in a unified compilation unit.
if CONFIG["JS_CODEGEN_NONE"]:
    SOURCES += [
        "WasmBaselineCompile.cpp",
        "WasmBCFrame.cpp",
        "WasmBCMemory.cpp",
        "WasmStubs.cpp",
    ]
else:
    UNIFIED_SOURCES += [
        "WasmBaselineCompile.cpp",
        "WasmBCFrame.cpp",
        "WasmBCMemory.cpp",
        "WasmStubs.cpp",
    ]

# Generate wasm/WasmBuiltinModuleGenerated.h from wasm/WasmBuiltinModule.yaml
GeneratedFile(
    "WasmBuiltinModuleGenerated.h",
    script="GenerateBuiltinModules.py",
    inputs=["WasmBuiltinModule.yaml"],
)

# Make sure all WebAssembly code is built with coverage instrumentation
# in FUZZING modes.
if CONFIG["FUZZING_INTERFACES"] or CONFIG["FUZZING_JS_FUZZILLI"]:
    include("/tools/fuzzing/libfuzzer-config.mozbuild")
